# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Odoo
*.log
*.pot

# Vault symlinks (link-brain.sh artifacts — don't commit the brain)
# No trailing slash: .agents, .agy, and graphify-out are SYMLINKS to the vault,
# and git's dir-only (trailing-slash) gitignore patterns don't match symlinks
# even when the target is a directory — they'd show as untracked despite this rule.
.agents
.agy
graphify-out
tests
doc
skills-lock.json
HANDOFF.md

# Secrets
.env
*.key
*.pem

# Local AI config (machine-specific, not for repo)
.claude/
.claudecoderc
.cursorrules
GEMINI.md

# Throwaway debug scratch work
scratch/

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
