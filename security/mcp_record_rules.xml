<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Record rule: Regular users can only read their own sessions -->
        <!-- Note: domain_force uses user.id (available in eval context) -->
        <record id="mcp_session_user_rule" model="ir.rule">
            <field name="name">User can only read own sessions</field>
            <field name="model_id" ref="model_mcp_session"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
        </record>

        <!-- Record rule: Manager users can read all sessions -->
        <record id="mcp_session_manager_rule" model="ir.rule">
            <field name="name">Manager can read all sessions</field>
            <field name="model_id" ref="model_mcp_session"/>
            <field name="groups" eval="[(4, ref('mcp_gateway.group_mcp_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <!-- Record rule: Admin users can read all sessions -->
        <record id="mcp_session_admin_rule" model="ir.rule">
            <field name="name">Admin can read all sessions</field>
            <field name="model_id" ref="model_mcp_session"/>
            <field name="groups" eval="[(4, ref('mcp_gateway.group_mcp_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <!-- Record rule: Regular users can only read messages from their own sessions -->
        <record id="mcp_session_message_user_rule" model="ir.rule">
            <field name="name">User can only read messages from own sessions</field>
            <field name="model_id" ref="model_mcp_session_message"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">[('session_id.user_id', '=', user.id)]</field>
        </record>

        <!-- Record rule: Manager users can read all session messages -->
        <record id="mcp_session_message_manager_rule" model="ir.rule">
            <field name="name">Manager can read all session messages</field>
            <field name="model_id" ref="model_mcp_session_message"/>
            <field name="groups" eval="[(4, ref('mcp_gateway.group_mcp_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <!-- Record rule: Admin users can read all session messages -->
        <record id="mcp_session_message_admin_rule" model="ir.rule">
            <field name="name">Admin can read all session messages</field>
            <field name="model_id" ref="model_mcp_session_message"/>
            <field name="groups" eval="[(4, ref('mcp_gateway.group_mcp_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>