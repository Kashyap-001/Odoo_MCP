<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mcp_echart_list" model="ir.ui.view">
        <field name="name">mcp.echart.list</field>
        <field name="model">mcp.echart</field>
        <field name="arch" type="xml">
            <list string="Charts">
                <field name="name"/>
                <field name="dashboard_id"/>
                <field name="is_shared"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="mcp_echart_form" model="ir.ui.view">
        <field name="name">mcp.echart.form</field>
        <field name="model">mcp.echart</field>
        <field name="arch" type="xml">
            <form string="EChart">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="dashboard_id"/>
                        <field name="is_shared"/>
                        <field name="active"/>
                    </group>
                    <separator string="Data Code"/>
                    <field name="data_code" widget="ace" options="{'mode': 'python'}" nolabel="1"/>
                    <separator string="EChart Options (JSON)"/>
                    <field name="options" widget="ace" options="{'mode': 'json'}" nolabel="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mcp_echart" model="ir.actions.act_window">
        <field name="name">Charts</field>
        <field name="res_model">mcp.echart</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No charts yet</p>
            <p>Charts are created by AI agents using the <b>create_echart</b> tool.</p>
        </field>
    </record>
</odoo>
