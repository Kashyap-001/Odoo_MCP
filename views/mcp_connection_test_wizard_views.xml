<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mcp_connection_test_wizard_form" model="ir.ui.view">
        <field name="name">mcp.connection.test.wizard.form</field>
        <field name="model">mcp.connection.test.wizard</field>
        <field name="arch" type="xml">
            <form string="Connection Test Result">
                <sheet>
                    <group>
                        <field name="status" widget="badge" decoration-success="status == 'success'" decoration-danger="status == 'error'"/>
                    </group>
                    <group>
                        <field name="message" options="{'horizontal': True}" readonly="1"/>
                    </group>
                    <group string="Available Models" invisible="not model_list">
                        <field name="model_list" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mcp_connection_test_wizard" model="ir.actions.act_window">
        <field name="name">Connection Test</field>
        <field name="res_model">mcp.connection.test.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>