<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==================== ISSUE TAGS ==================== -->

    <!-- Action for Issue Tags -->
    <record id="action_mcp_issue_tag" model="ir.actions.act_window">
        <field name="name">Issue Tags</field>
        <field name="res_model">mcp.issue.tag</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ==================== ISSUES ==================== -->

    <!-- Action for Issues -->
    <record id="action_mcp_issue" model="ir.actions.act_window">
        <field name="name">Issues</field>
        <field name="res_model">mcp.issue</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="context">{'search_default_needs_triage': 1}</field>
    </record>

    <!-- Search View -->
    <record id="view_mcp_issue_search" model="ir.ui.view">
        <field name="name">mcp.issue.search</field>
        <field name="model">mcp.issue</field>
        <field name="arch" type="xml">
            <search string="Search Issues">
                <field name="name"/>
                <field name="description"/>
                <field name="reporter_id"/>
                <field name="assignee_id"/>
                <separator/>
                <filter string="Needs Triage" name="needs_triage"
                        domain="[('state', '=', 'needs_triage')]"/>
                <filter string="Needs Info" name="needs_info"
                        domain="[('state', '=', 'needs_info')]"/>
                <filter string="Ready for Agent" name="ready_for_agent"
                        domain="[('state', '=', 'ready_for_agent')]"/>
                <filter string="Bugs" name="bugs"
                        domain="[('category', '=', 'bug')]"/>
                <filter string="Enhancements" name="enhancements"
                        domain="[('category', '=', 'enhancement')]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category"
                            context="{'group_by': 'category'}"/>
                    <filter string="State" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Assignee" name="group_assignee"
                            context="{'group_by': 'assignee_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- List View -->
    <record id="view_mcp_issue_list" model="ir.ui.view">
        <field name="name">mcp.issue.list</field>
        <field name="model">mcp.issue</field>
        <field name="arch" type="xml">
            <list string="Issues" multi_edit="1" default_order="priority desc, create_date desc">
                <field name="priority" widget="priority" width="60px"/>
                <field name="state" widget="badge"
                       decoration-danger="state in ('needs_triage', 'needs_info')"
                       decoration-success="state in ('done',)"
                       decoration-warning="state in ('ready_for_agent', 'ready_for_human')"/>
                <field name="category" widget="badge"
                       decoration-primary="category == 'bug'"
                       decoration-info="category == 'enhancement'"/>
                <field name="name"/>
                <field name="reporter_id"/>
                <field name="assignee_id"/>
                <field name="create_date" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_mcp_issue_kanban" model="ir.ui.view">
        <field name="name">mcp.issue.kanban</field>
        <field name="model">mcp.issue</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" group_create="false" js_class="issue_kanban">
                <field name="id"/>
                <field name="name"/>
                <field name="category"/>
                <field name="priority"/>
                <field name="reporter_id"/>
                <field name="assignee_id"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex flex-column gap-2">
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge"
                                       t-att-class="record.category.raw_value === 'bug' ? 'bg-danger' : 'bg-info'">
                                    <t t-esc="record.category.raw_value"/>
                                </span>
                                <span class="badge bg-secondary">
                                    <t t-esc="record.state.raw_value"/>
                                </span>
                            </div>
                            <div class="fw-bold">
                                <field name="name"/>
                            </div>
                            <div class="text-muted small">
                                <field name="reporter_id"/> →
                                <field name="assignee_id"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_mcp_issue_form" model="ir.ui.view">
        <field name="name">mcp.issue.form</field>
        <field name="model">mcp.issue</field>
        <field name="arch" type="xml">
            <form string="Issue">
                <header>
                    <button name="action_mark_needs_triage" string="Needs Triage"
                            class="btn-secondary" type="object"
                            invisible="state != 'needs_info'"/>
                    <button name="action_mark_needs_info" string="Needs Info"
                            class="btn-warning" type="object"
                            invisible="state in ('needs_info', 'done', 'wontfix')"/>
                    <button name="action_mark_ready_for_agent" string="Ready for Agent"
                            class="btn-primary" type="object"
                            invisible="state in ('ready_for_agent', 'done', 'wontfix')"/>
                    <button name="action_mark_ready_for_human" string="Ready for Human"
                            class="btn-success" type="object"
                            invisible="state in ('ready_for_human', 'done', 'wontfix')"/>
                    <button name="action_mark_wontfix" string="Won't Fix"
                            class="btn-danger" type="object"
                            invisible="state in ('wontfix', 'done')"/>
                    <button name="action_mark_done" string="Done"
                            class="btn-success" type="object"
                            invisible="state == 'done'"/>
                    <field name="state" widget="statusbar" statusbar_visible="needs_triage,needs_info,ready_for_agent,ready_for_human,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" placeholder="Brief summary"/>
                            <field name="category" widget="radio"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group>
                            <field name="reporter_id"/>
                            <field name="assignee_id"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" nolabel="1" placeholder="Detailed description, steps to reproduce..."/>
                    </group>
                    <group string="Triage">
                        <field name="triage_notes" nolabel="1" placeholder="Notes from triage process..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>