<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View - List of all sessions -->
    <record id="view_mcp_session_tree" model="ir.ui.view">
        <field name="name">mcp.session.tree</field>
        <field name="model">mcp.session</field>
        <field name="arch" type="xml">
            <list string="Sessions" decoration-success="state=='done'" decoration-danger="state=='error'">
                <field name="name" />
                <field name="agent_id" />
                <field name="user_id" />
                <field name="state" widget="badge"
                    decoration-success="state=='done'"
                    decoration-danger="state=='error'"
                    decoration-info="state=='active'" />
                <field name="source" widget="badge" optional="show" />
                <field name="input_tokens" />
                <field name="output_tokens" />
                <field name="estimated_cost_usd" />
                <field name="tool_call_count" string="Tool Calls" optional="show" />
                <field name="duration_seconds" string="Duration (s)" digits="[6,1]" optional="show" />
                <field name="create_date" />
            </list>
        </field>
    </record>

    <!-- Form View - Session with chatter for chat -->
    <record id="view_mcp_session_form" model="ir.ui.view">
        <field name="name">mcp.session.form</field>
        <field name="model">mcp.session</field>
        <field name="arch" type="xml">
            <form string="Session">
                <sheet>
                    <!-- Action buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_export_transcript" type="object"
                            class="oe_stat_button" icon="fa-download"
                            string="Export Transcript" />
                        <button name="action_replay" type="object"
                            class="oe_stat_button" icon="fa-play"
                            string="Replay" />
                    </div>

                    <!-- Session details -->
                    <group>
                        <group>
                            <field name="name" readonly="1" force_save="1" />
                            <field name="is_pinned" />
                            <field name="agent_id" />
                            <field name="user_id" />
                        </group>
                        <group>
                            <field name="state" widget="badge"
                                decoration-success="state=='done'"
                                decoration-danger="state=='error'"
                                decoration-info="state=='active'" />
                            <field name="source" />
                            <field name="input_tokens" />
                            <field name="output_tokens" />
                            <field name="estimated_cost_usd" />
                            <field name="tool_call_count" string="Tool Calls" />
                            <field name="duration_seconds" string="Duration (s)" digits="[6,1]" />
                        </group>
                    </group>

                    <!-- Error message -->
                    <group invisible="state != 'error'">
                        <field name="error_message" />
                    </group>

                    <!-- Webhook trigger info -->
                    <group string="Webhook Trigger" invisible="not trigger_model">
                        <field name="trigger_model" />
                        <field name="trigger_res_id" />
                    </group>

                    <!-- Message breakdown tab -->
                    <notebook>
                        <page string="Messages" name="messages">
                            <field name="session_message_ids" mode="list">
                                <list create="0" delete="0">
                                    <field name="create_date" string="Time" />
                                    <field name="role" widget="badge"
                                        decoration-info="role=='user'"
                                        decoration-success="role=='assistant'"
                                        decoration-warning="role=='tool_call'"
                                        decoration-muted="role=='tool_result'" />
                                    <field name="tool_name" optional="show" />
                                    <field name="token_count" string="Tokens" optional="show" />
                                    <field name="duration_ms" string="ms" optional="show" />
                                    <field name="content" string="Content" />
                                </list>
                            </field>
                        </page>
                    </notebook>

                    <!-- Chatter for conversation -->
                    <chatter />
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View - Filter and search sessions -->
    <record id="view_mcp_session_search" model="ir.ui.view">
        <field name="name">mcp.session.search</field>
        <field name="model">mcp.session</field>
        <field name="arch" type="xml">
            <search string="Search Sessions">
                <field name="name" string="Session Name" />
                <field name="agent_id" string="Agent" />
                <field name="user_id" string="User" />
                <separator />
                <filter name="active_sessions" string="Active" domain="[('state', '=', 'active')]" />
                <filter name="done_sessions" string="Completed" domain="[('state', '=', 'done')]" />
                <filter name="error_sessions" string="Errors" domain="[('state', '=', 'error')]" />
                <separator />
                <filter name="pinned_sessions" string="Pinned" domain="[('is_pinned', '=', True)]" />
                <separator />
                <filter name="source_api" string="API" domain="[('source', '=', 'api')]" />
                <filter name="source_webhook" string="Webhook" domain="[('source', '=', 'webhook')]" />
                <separator />
                <filter name="today_sessions" string="Today"
                    domain="[('create_date', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')), ('create_date', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]" />
                <filter name="this_week" string="This Week"
                    domain="[('create_date', '&gt;=', (context_today() - relativedelta(weeks=1)).strftime('%Y-%m-%d'))]" />
                <filter name="this_month" string="This Month"
                    domain="[('create_date', '&gt;=', (context_today() - relativedelta(months=1)).strftime('%Y-%m-%d'))]" />
                <separator />
                <group expand="0" string="Group By">
                    <filter name="group_agent" string="Agent" domain="[]" context="{'group_by': 'agent_id'}" />
                    <filter name="group_user" string="User" domain="[]" context="{'group_by': 'user_id'}" />
                    <filter name="group_state" string="State" domain="[]" context="{'group_by': 'state'}" />
                    <filter name="group_source" string="Source" domain="[]" context="{'group_by': 'source'}" />
                    <filter name="group_week" string="Week" domain="[]" context="{'group_by': 'create_date:week'}" />
                    <filter name="group_month" string="Month" domain="[]" context="{'group_by': 'create_date:month'}" />
                </group>
            </search>
        </field>
    </record>
</odoo>
