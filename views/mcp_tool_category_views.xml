<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View - List of all tool categories -->
    <record id="mcp_tool_category_list" model="ir.ui.view">
        <field name="name">mcp.tool.category.list</field>
        <field name="model">mcp.tool.category</field>
        <field name="arch" type="xml">
            <list string="Tool Categories">
                <field name="name" />
                <field name="sequence" />
            </list>
        </field>
    </record>

    <!-- Form View - Create/Edit tool category -->
    <record id="mcp_tool_category_form" model="ir.ui.view">
        <field name="name">mcp.tool.category.form</field>
        <field name="model">mcp.tool.category</field>
        <field name="arch" type="xml">
            <form string="Tool Category">
                <sheet>
                    <group>
                        <group>
                            <field name="name" required="True" />
                            <field name="sequence" />
                        </group>
                        <group>
                            <field name="description" />
                        </group>
                    </group>
                    <separator string="Tools in This Category" />
                    <field name="tool_ids" widget="one2many_list" nolabel="1">
                        <list>
                            <field name="name" />
                            <field name="display_name_label" string="Display" />
                            <field name="tool_type" />
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View - Filter and search categories -->
    <record id="mcp_tool_category_search" model="ir.ui.view">
        <field name="name">mcp.tool.category.search</field>
        <field name="model">mcp.tool.category</field>
        <field name="arch" type="xml">
            <search string="Tool Categories">
                <field name="name" string="Category Name" />
                <field name="description" />
            </search>
        </field>
    </record>

    <!-- Action - Window action for tool categories -->
    <record id="mcp_tool_category_action" model="ir.actions.act_window">
        <field name="name">Tool Categories</field>
        <field name="res_model">mcp.tool.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first tool category!
            </p>
            <p>
                Tool categories help organize and group related tools for better user experience.
            </p>
        </field>
    </record>
</odoo>