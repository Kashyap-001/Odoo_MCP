<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View - List of all access rules -->
    <record id="view_mcp_access_rule_tree" model="ir.ui.view">
        <field name="name">mcp.access.rule.tree</field>
        <field name="model">mcp.access.rule</field>
        <field name="arch" type="xml">
            <list string="Access Rules">
                <field name="name" />
                <field name="group_ids" />
                <field name="agent_ids" widget="many2many_tags" />
                <field name="tool_ids" widget="many2many_tags" />
                <field name="rate_limit_day" />
            </list>
        </field>
    </record>

    <!-- Form View - Create/Edit access rule -->
    <record id="view_mcp_access_rule_form" model="ir.ui.view">
        <field name="name">mcp.access.rule.form</field>
        <field name="model">mcp.access.rule</field>
        <field name="arch" type="xml">
            <form string="Access Rule">
                <sheet>
                    <!-- Basic info -->
                    <group>
                        <field name="name" required="1" />
                        <field name="group_ids" required="1" />
                    </group>

                    <!-- Permissions section -->
                    <group string="Permissions">
                        <group>
                            <field name="can_view_sessions" />
                            <field name="can_export" />
                        </group>
                    </group>

                    <!-- Rate limiting section -->
                    <group string="Rate Limiting">
                        <group>
                            <field name="rate_limit_day" />
                            <field name="rate_limit_month" />
                        </group>
                    </group>

                    <!-- Accessible agents and tools -->
                    <field name="agent_ids" widget="many2many_tags" nolabel="1" colspan="2" string="Accessible Agents" />
                    <field name="tool_ids" widget="many2many" nolabel="1" colspan="2" string="Accessible Tools" />
                </sheet>
            </form>
        </field>
    </record>
</odoo>