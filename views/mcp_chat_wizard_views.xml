<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View - Chat wizard for selecting agent and starting chat -->
    <record id="view_mcp_chat_wizard_form" model="ir.ui.view">
        <field name="name">mcp.chat.wizard.form</field>
        <field name="model">mcp.chat.wizard</field>
        <field name="arch" type="xml">
            <form string="Start Chat">
                <group>
                    <field name="agent_id" required="1" />
                </group>
                <footer>
                    <button name="action_start_chat" type="object" string="Start Chat" class="btn-primary" />
                    <button string="Cancel" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
</odoo>