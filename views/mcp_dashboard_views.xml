<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mcp_dashboard_list" model="ir.ui.view">
        <field name="name">mcp.dashboard.list</field>
        <field name="model">mcp.dashboard</field>
        <field name="arch" type="xml">
            <list string="Dashboards">
                <field name="name"/>
                <field name="chart_count"/>
                <field name="is_shared"/>
            </list>
        </field>
    </record>

    <record id="mcp_dashboard_form" model="ir.ui.view">
        <field name="name">mcp.dashboard.form</field>
        <field name="model">mcp.dashboard</field>
        <field name="arch" type="xml">
            <form string="Dashboard">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="icon"/>
                        <field name="sequence"/>
                        <field name="is_shared" widget="boolean_toggle"/>
                    </group>
                    <field name="chart_ids"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mcp_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboards</field>
        <field name="res_model">mcp.dashboard</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
