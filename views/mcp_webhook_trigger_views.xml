<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View - List of all webhooks -->
    <record id="view_mcp_webhook_tree" model="ir.ui.view">
        <field name="name">mcp.webhook.trigger.tree</field>
        <field name="model">mcp.webhook.trigger</field>
        <field name="arch" type="xml">
            <list string="Webhooks">
                <field name="name" />
                <field name="trigger_model" />
                <field name="agent_id" />
                <field name="token" />
                <field name="active" />
            </list>
        </field>
    </record>

    <!-- Form View - Create/Edit webhook -->
    <record id="view_mcp_webhook_form" model="ir.ui.view">
        <field name="name">mcp.webhook.trigger.form</field>
        <field name="model">mcp.webhook.trigger</field>
        <field name="arch" type="xml">
            <form string="Webhook Trigger">
                <sheet>
                    <group>
                        <group>
                            <field name="name" required="1" />
                            <field name="trigger_model" required="1" />
                            <field name="agent_id" required="1" />
                        </group>
                        <group>
                            <field name="active" />
                            <field name="token" readonly="1" />
                        </group>
                    </group>
                    <field name="description" widget="html" nolabel="1" />
                    <group string="Webhook URL">
                        <field name="webhook_url" readonly="1" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>