<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mcp_webhook_tree" model="ir.ui.view">
        <field name="name">mcp.webhook.trigger.tree</field>
        <field name="model">mcp.webhook.trigger</field>
        <field name="arch" type="xml">
            <list string="Webhooks">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="agent_id"/>
                <field name="last_triggered"/>
                <field name="trigger_count"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_mcp_webhook_form" model="ir.ui.view">
        <field name="name">mcp.webhook.trigger.form</field>
        <field name="model">mcp.webhook.trigger</field>
        <field name="arch" type="xml">
            <form string="Webhook Trigger">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_generate_token" type="object"
                                class="oe_stat_button" icon="fa-refresh"
                                string="Regenerate Token"/>
                    </div>
                    <group>
                        <group>
                            <field name="name" required="1"/>
                            <field name="agent_id" required="1"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="last_triggered" readonly="1"/>
                            <field name="trigger_count" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Message" name="message">
                            <group string="Message sent to AI">
                                <field name="message_template" required="1" nolabel="1" colspan="2"
                                       placeholder="e.g. New lead arrived: {{ record.name }} — qualify it and suggest next steps."/>
                            </group>
                        </page>

                        <page string="Endpoint" name="endpoint">
                            <group string="Inbound — n8n calls Odoo">
                                <div class="text-muted mb-2" colspan="2">
                                    Copy this URL into your n8n HTTP Request node. n8n calls Odoo → AI runs → result returned.
                                </div>
                                <field name="webhook_url" readonly="1" widget="CopyClipboardChar"
                                       nolabel="1" colspan="2"/>
                                <field name="token" readonly="1" widget="CopyClipboardChar"
                                       nolabel="1" colspan="2"/>
                            </group>
                            <group string="Outbound — Odoo calls n8n">
                                <div class="text-muted mb-2" colspan="2">
                                    Paste your n8n Webhook Trigger URL here. After the AI runs, Odoo POSTs the result back to n8n.
                                </div>
                                <field name="outbound_url" nolabel="1" colspan="2"
                                       placeholder="https://your-n8n.com/webhook/abc123"/>
                                <field name="outbound_secret" nolabel="1" colspan="2"
                                       placeholder="Optional bearer token from n8n"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
